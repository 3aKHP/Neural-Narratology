<?xml version="1.0" encoding="UTF-8"?>
<character_card>
    <!-- [基础信息] -->
    <basic_info>
        <name></name>
        <model_type></model_type>
        <intro>
        </intro>
    </basic_info>

    <!-- [外在形象] -->
    <visual>
        <attire></attire>
        <appearance></appearance>
    </visual>

    <!-- [内在灵魂 (V6.0 Holographic Core)] -->
    <soul>
        <!-- 1. 静态认知与纹理 -->
        <cognitive_core>
            <mbti type="">
                <dominant_function></dominant_function>
                <inferior_function></inferior_function>
            </mbti>
            <alignment type="">
                <creed></creed>
                <boundary></boundary>
            </alignment>
        </cognitive_core>

        <psycho_texture>
            <emotional_spectrum>
                <base_mood></base_mood>
                <stress_response></stress_response>
            </emotional_spectrum>
            <value_hierarchy>
                <primary></primary>
                <neglected></neglected>
            </value_hierarchy>
            <intimacy_mechanics>
                <warming_rate></warming_rate>
                <love_language></love_language>
                <boundary_style></boundary_style>
            </intimacy_mechanics>
        </psycho_texture>

        <!-- 2. 语言指纹接口 -->
        <linguistic_model>
            <syntax_rhythm>
                <sentence_length></sentence_length>
                <punctuation></punctuation>
            </syntax_rhythm>
            <lexicon>
                <domain_keywords></domain_keywords>
                <taboo_words></taboo_words>
                <catchphrases></catchphrases>
            </lexicon>
            <dialogue_logic>
                <opening_stance></opening_stance>
                <topic_control></topic_control>
            </dialogue_logic>
            <rhetoric>
                <metaphor_source></metaphor_source>
                <sensory_bias></sensory_bias>
            </rhetoric>
        </linguistic_model>

        <!-- 3. 心理动力学 -->
        <psycho_dynamics>
            <axis_x name="">
                <desc></desc>
                <trigger_logic></trigger_logic>
            </axis_x>
            <axis_y name="">
                <desc></desc>
                <trigger_logic></trigger_logic>
            </axis_y>
            <initial_state>X=0, Y=0</initial_state>
        </psycho_dynamics>

        <!-- 4. 行为逻辑门 -->
        <logic_gates>
            <gate id="Default" condition="Default">
            </gate>
            <gate id="State_A" condition="">
            </gate>
            <gate id="State_B" condition="">
            </gate>
        </logic_gates>

        <!-- 5. 常规设定 -->
        <description></description>
        <goals></goals>
        <flaws></flaws>
    </soul>

    <!-- [世界与关系] -->
    <world>
        <history></history>
        <world_view></world_view>
        <relationships>
            <user_relation></user_relation>
            <others></others>
        </relationships>
        <residence></residence>
    </world>

    <!-- [附加属性] -->
    <assets>
        <likes></likes>
        <dislikes></dislikes>
        <inventory></inventory>
        <skills></skills>
    </assets>
</character_card>
